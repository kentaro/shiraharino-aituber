{
  "name": "shiraharino-aituber",
  "version": "0.1.0",
  "private": false,
  "description": "白羽リノ 24/7 AITuber — HTML/CSS broadcast page + headless Chrome + Xvfb + ffmpeg → YouTube Live, self-contained on a single server.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/broadcast.ts --bundle --format=iife --target=es2020 --outfile=web/broadcast.js",
    "watch": "esbuild src/broadcast.ts --bundle --format=iife --target=es2020 --outfile=web/broadcast.js --watch",
    "typecheck": "tsc --noEmit",
    "serve": "python3 -m http.server 8777 --directory web"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
